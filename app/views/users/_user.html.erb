<div id="<%= dom_id user %>">
  <div>
    <strong>Name:</strong>
    <%= user.name %>
  </div>

  <div>
    <strong>Email:</strong>
    <%= user.email %>
  </div>

  <div>
    <strong>Canvas token:</strong>
    <%= user.canvas_token %>
  </div>

  <div>
    <strong>Calendar preference:</strong>
    <%= user.calendar_preference %>
  </div>

</div>
