<%= form_with(model: user, html: { multipart: true }) do |form| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(user.errors.count, "error") %> prohibited this account from being saved:</strong>
      <ul>
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <label class="form-label">Name <span style="color:#E24B4A;">*</span></label>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <label class="form-label">Email <span style="color:#E24B4A;">*</span></label>
    <%= form.email_field :email, class: "form-control" %>
  </div>

  <div class="mb-3">
    <label class="form-label">Password <span style="color:#E24B4A;">*</span></label>
    <%= form.password_field :password, class: "form-control", autocomplete: "new-password" %>
  </div>

  <div class="mb-3">
    <label class="form-label">Password Confirmation <span style="color:#E24B4A;">*</span></label>
    <%= form.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
  </div>

  <% if user.persisted? %>
    <div class="mb-3">
      <label class="form-label">Profile Photo</label>
      <% if user.avatar.attached? %>
        <div class="mb-2">
          <%= image_tag user.avatar, alt: "Current avatar", style: "width:64px; height:64px; border-radius:50%; object-fit:cover;" %>
        </div>
      <% end %>
      <%= form.file_field :avatar, accept: "image/png,image/jpeg,image/webp", class: "form-control" %>
      <div class="form-text">PNG, JPG, or WebP. Max 5 MB.</div>
    </div>
  <% end %>

  <div class="d-flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", current_user ? user_path(current_user) : login_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>