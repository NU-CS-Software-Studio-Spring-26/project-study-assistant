<% content_for :title, "Account" %>

<h1 class="h2 mb-3">Account</h1>

<div class="card">
  <div class="card-body">
    <%= render @user %>
  </div>
</div>

<div class="mt-3">
  <%= link_to "View My Assignments", assignments_path, class: "btn btn-dark" %>
  <%= link_to "Edit Profile", edit_user_path(@user), class: "btn btn-secondary" %>
  <%= button_to "Delete Account", @user, method: :delete, class: "btn btn-danger mt-2", form: { data: { turbo_confirm: "Delete your account?" } } %>
</div>
