<% content_for :title, @assignment.title %>

<div class="d-flex justify-content-between align-items-start mb-3">
  <div>
    <h1 class="h2 mb-1"><%= @assignment.title %></h1>
    <p class="text-muted mb-0"><%= @assignment.course_name %></p>
  </div>
  <%= link_to "Back", assignments_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card">
  <div class="card-body">
    <%= render @assignment %>
  </div>
</div>

<div class="d-flex gap-2 mt-3">
  <%= link_to "Edit", edit_assignment_path(@assignment), class: "btn btn-primary" %>
  <%= button_to "Delete", @assignment, method: :delete, class: "btn btn-outline-danger", form: { data: { turbo_confirm: "Delete this assignment?" } } %>
</div>
