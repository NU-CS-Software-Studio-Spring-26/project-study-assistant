<div id="<%= dom_id assignment %>">
  <div class="mb-2">
    <strong>Title:</strong>
    <%= assignment.title %>
  </div>

  <div class="mb-2">
    <strong>Course name:</strong>
    <%= assignment.course_name %>
  </div>

  <div class="mb-2">
    <strong>Due date:</strong>
    <%= assignment.due_date&.strftime("%b %d, %Y %I:%M %p") %>
    <% if assignment.imported_from_canvas? && !assignment.due_time_confirmed? %>
      <span class="badge text-bg-warning ms-1">Time needs confirmation</span>
    <% end %>
  </div>

  <div class="mb-2">
    <strong>Estimated hours:</strong>
    <%= assignment.estimated_hours.presence || "Not set" %>
  </div>

  <div>
    <strong>Synced to calendar:</strong>
    <%= assignment.synced_to_calendar? ? "Yes" : "No" %>
  </div>

  <div>
    <strong>Source:</strong>
    <%= assignment.imported_from_canvas? ? "Canvas iCal" : "Manual" %>
  </div>

</div>
