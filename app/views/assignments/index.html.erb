<% content_for :title, "Assignments" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="h2 mb-1">Assignments</h1>
    <p class="text-muted mb-0">Track deadlines by course and due time.</p>
  </div>
  <%= link_to "New Assignment", new_assignment_path, class: "btn btn-primary" %>
</div>

<%= form_with url: assignments_path, method: :get, class: "row g-2 align-items-end mb-3" do |form| %>
  <div class="col-md-7">
    <%= form.label :q, "Search", class: "form-label" %>
    <%= form.search_field :q, value: @query, class: "form-control", placeholder: "Search title or course" %>
  </div>
  <div class="col-md-3">
    <%= form.label :sort, "Sort", class: "form-label" %>
    <%= form.select :sort, [["Due soonest", "due_asc"], ["Due latest", "due_desc"]], { selected: @sort }, class: "form-select" %>
  </div>
  <div class="col-md-2 d-grid">
    <%= form.submit "Apply", class: "btn btn-outline-primary" %>
  </div>
<% end %>

<% if @assignments.any? %>
  <table class="table table-striped table-hover align-middle">
    <thead>
      <tr>
        <th>Title</th>
        <th>Course</th>
        <th>Due Date</th>
        <th>Estimated Hours</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @assignments.each do |assignment| %>
        <tr>
          <td><%= assignment.title %></td>
          <td><%= assignment.course_name %></td>
          <td><%= assignment.due_date&.strftime("%b %d, %Y %I:%M %p") %></td>
          <td><%= assignment.estimated_hours.presence || "Not set" %></td>
          <td class="text-end"><%= link_to "View", assignment, class: "btn btn-sm btn-outline-dark" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="alert alert-info">
    No assignments found. <%= link_to "Create your first assignment", new_assignment_path, class: "alert-link" %>.
  </div>
<% end %>
