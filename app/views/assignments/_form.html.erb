<%= form_with(model: assignment) do |form| %>
  <% if assignment.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(assignment.errors.count, "error") %> prohibited this assignment from being saved:</strong>

      <ul>
        <% assignment.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :course_name, class: "form-label" %>
    <%= form.text_field :course_name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :due_date, class: "form-label" %>
    <%= form.datetime_field :due_date, class: "form-control" %>
    <% if assignment.imported_from_canvas? && !assignment.due_time_confirmed? %>
      <div class="form-text">Canvas iCal does not provide exact due times. Saving this form confirms the time above.</div>
    <% end %>
  </div>

  <div class="form-check mb-3">
    <%= form.checkbox :synced_to_calendar, class: "form-check-input" %>
    <%= form.label :synced_to_calendar, class: "form-check-label" %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", assignments_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
