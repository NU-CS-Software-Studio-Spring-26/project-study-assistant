<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "TideTogether" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="TideTogether">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#F38046">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </head>

  <body class="d-flex flex-column min-vh-100 <%= content_for?(:body_class) ? yield(:body_class) : '' %>">

    <% unless content_for?(:hide_nav) %>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2 logo-brand" href="/">
          <img src="/logo.svg" alt="TideTogether Logo" height="32">
          <span class="fw-bold fs-4 text-dark">TideTogether</span>
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
          <div class="navbar-nav me-auto">
            <% if current_user %>
              <%= link_to "Assignments", assignments_path, class: "nav-link" %>
              <%= link_to "Study Groups", study_groups_path, class: "nav-link" %>
            <% end %>
          </div>
          
          <div class="navbar-nav">
            <% if current_user %>
              <%= link_to "Account", user_path(current_user), class: "nav-link" %>
              <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-outline-light btn-sm ms-lg-2 mt-2 mt-lg-0" %>
            <% else %>
              <%= link_to "Login", login_path, class: "nav-link" %>
              <%= link_to "Sign Up", new_user_path, class: "btn btn-primary btn-sm ms-lg-2 mt-2 mt-lg-0" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
    <% end %>

    <main class="<%= content_for?(:full_page) ? '' : 'container my-4' %> flex-grow-1">
      <% flash.each do |type, message| %>
        <% alert_class = type.to_s == "notice" ? "success" : "danger" %>
        <div class="alert alert-<%= alert_class %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="border-top py-3 text-center small">
      <div class="container">
        <div class="d-flex justify-content-center gap-3">
          <%= link_to "Privacy", privacy_path, class: "text-decoration-none" %>
          <%= link_to "About us", about_path, class: "text-decoration-none" %>
          <%= link_to "Repo", "https://github.com/NU-CS-Software-Studio-Spring-26/project-study-assistant", target: "_blank", rel: "noopener", class: "text-decoration-none" %>
        </div>
      </div>
    </footer>
  </body>
</html>