  <div class="mb-1 text-dark"><strong>Description:</strong></div>
  <div class="description-content border-start border-3 ps-3 py-1 mb-3 text-break text-secondary">
    <%= simple_format(group.description, class: "mb-0") %>
  </div>
<% end %>