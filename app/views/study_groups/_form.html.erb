<%= form_with model: study_group, data: { controller: "study-group-time" } do |form| %>
  <% if study_group.errors.any? %>
    <div class="alert alert-danger border study-subtitle">
      <strong>Could not save group:</strong>
      <ul class="mb-0 mt-2">
        <% study_group.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, "Group Name", class: "form-label search-label" %>
    <%= form.text_field :name, class: "form-control custom-search-input", placeholder: "BIO 101 Midterm Sprint" %>
  </div>

  <p class="study-subtitle mb-3">Saving as <strong style="color: #4a3e3d;"><%= current_user.name %></strong></p>

  <div class="row g-3">
    <div class="col-md-6">
      <%= form.label :start_time, "Start Time", class: "form-label search-label" %>
      <%= form.datetime_local_field :start_time,
        class: "form-control custom-search-input",
        data: {
          study_group_time_target: "start",
          action: "input->study-group-time#syncEnd change->study-group-time#syncEnd"
        } %>
    </div>

    <div class="col-md-6">
      <%= form.label :end_time, "End Time", class: "form-label search-label" %>
      <%= form.datetime_local_field :end_time,
        class: "form-control custom-search-input",
        data: {
          study_group_time_target: "end",
          action: "input->study-group-time#markManual change->study-group-time#markManual"
        } %>
    </div>
  </div>

  <div class="row g-3 mt-1">
    <div class="col-md-6">
      <%= form.label :location_mode, "Online Or In Person", class: "form-label search-label" %>
      <%= form.select :location_mode, StudyGroup::LOCATION_MODES, { prompt: "Choose one" }, class: "form-select custom-search-input" %>
    </div>

    <div class="col-md-6">
      <%= form.label :communication_style, "Group Style", class: "form-label search-label" %>
      <%= form.select :communication_style, StudyGroup::COMMUNICATION_STYLES, { prompt: "Choose one" }, class: "form-select custom-search-input" %>
    </div>
  </div>

  <div class="mb-3 mt-3">
    <%= label_tag :custom_tags, "Custom Tags", class: "form-label search-label" %>
    <%= text_field_tag :custom_tags, study_group.tags.to_a.join(", "), class: "form-control custom-search-input", placeholder: "homework, library, calculus" %>
  </div>

  <div class="mb-3">
    <%= form.label :join_password, "Join Password", class: "form-label search-label" %>
    <%= form.password_field :join_password, value: study_group.join_password, class: "form-control custom-search-input", placeholder: "Leave blank for open group" %>
  </div>

  <!-- Choose Group Banner Section -->
  <div class="mb-5 mt-4">
  <div class="row row-cols-3 g-4">
    <% presets = [
         { name: "Arriety", url: "https://i.redd.it/8r788se4ay661.jpg", css: nil },
         { name: "Howls Moving Castle", url: "https://external-preview.redd.it/howls-moving-castle-v0-imYs0f7aP4r1jKfehK-eehRjJvEVCETuT43_NuMCeSo.jpg?auto=webp&s=adcd88fa0f3936b022a6b929b199d96408a1820c", css: nil },
         { name: "Totoro", url: "https://preview.redd.it/i-made-a-set-of-totoro-wallpaper-for-pc-and-mobile-phone-v0-aqhyo4zoqiqb1.jpg?width=4000&format=pjpg&auto=webp&s=529ce3d113d751095d7670e770b4bbdc2feadb3e", css: nil },
         { name: "Spirited Away", url: "https://c4.wallpaperflare.com/wallpaper/556/593/206/anime-studio-ghibli-spirted-away-spirited-away-wallpaper-preview.jpg", css: nil },
         { name: "Ponyo", url: "https://images-wixmp-ed30a86b8c4ca887773594c2.wixmp.com/f/134dd0d8-53a6-44e0-9e48-cb6bcf7f8f71/d88hvf1-12438e3d-3a56-4912-9d43-5cda1ec571af.jpg/v1/fill/w_1024,h_640,q_75,strp/ponyo_wallpaper_hd_by_atonyynot_d88hvf1-fullview.jpg?token=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..Dn7eaL-cLWmYF9RNwnGL2aQ5xWFA7wR74s-7n2DbpAQ
         ", css: nil },


     
         # 2. Minimalist Solid Colors
         { name: "Cerulean Blue", url: "banner-solid-cerulean", css: "background-color: #2A52BE;" },
         { name: "Solid Orange", url: "banner-solid-orange", css: "background-color: #D87A53;" },

         # 3. Modern Tech Gradients
         { name: "Sunset", url: "banner-grad-sunset", css: "background: linear-gradient(135deg, #0a138f 0%, #c70a4f 100%);" },
         { name: "Emerald", url: "banner-grad-mint", css: "background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);" }
       ] %>

    <% presets.each_with_index do |preset, idx| %>
      <div class="ol mb-2">
        <label class="w-100 d-flex flex-column align-items-center position-relative style-preset-container" style="cursor: pointer;">
          
          <%= form.radio_button :banner_url, preset[:url], class: "form-check-input style-preset-radio mb-3", checked: (idx == 0) %>
          
          <div class="w-100 style-preset-strip overflow-hidden shadow-sm" style="border-radius: 12px; height: 65px;">
            <% if preset[:css].nil? %>
              <img src="<%= preset[:url] %>" alt="<%= preset[:name] %> Preview" class="w-100 h-100 object-fit-cover" style="display: block;">
            <% else %>
              <div class="w-100 h-100" style="<%= preset[:css] %>"></div>
            <% end %>
          </div>

          <div class="mt-3 text-center">
            <span class="study-subtitle text-dark d-block" style="font-size: 1.0em; letter-spacing: 0.05em; font-family: monospace;">
              <%= preset[:name] %>
            </span>
          </div>

        </label>
      </div>
    <% end %>
  </div>
</div>

  <div class="mb-4">
    <%= form.label :description, "Group Description", class: "form-label search-label" %>
    <%= form.text_area :description, 
        class: "form-control custom-search-input", 
        placeholder: "Write what you want out of a study group...", 
        rows: 5 %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit class: "custom-orange-btn" %>
    <%= link_to "Cancel", study_groups_path, class: "btn btn-outline-secondary study-subtitle d-inline-flex align-items-center px-3", style: "border-radius: 8px;" %>
  </div>
<% end %>


