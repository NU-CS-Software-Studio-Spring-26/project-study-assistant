<% content_for :title, "Groups" %>


<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="study-title mb-0">Study Groups</h1>
    <p class="study-subtitle">Find a group that matches your study style.</p>
  </div>
  <%= link_to "New Study Group", new_study_group_path, class: "custom-orange-btn text-decoration-none d-inline-flex align-items-center justify-content-center" %>
</div>

<div data-controller="study-group-grid" data-study-group-grid-columns-value="3" data-study-group-grid-storage-key-value="study-group-grid-columns">
  <%= form_with url: study_groups_path, method: :get, class: "row g-3 align-items-end mb-4" do |form| %>
    <div class="col-12 col-lg-5">
      <%= form.label :query, "Search by title, tags, or study style", class: "form-label search-label" %>
      <%= form.search_field :query, value: @query, class: "form-control custom-search-input", placeholder: "e.g. calculus, online, quiet" %>
    </div>
    <div class="col-12 col-lg-7">
      <div class="d-flex flex-wrap align-items-end gap-3 study-search-controls">
        <div class="d-flex gap-2 flex-wrap align-items-end">
          <%= form.submit "Search", class: "custom-orange-btn" %>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap study-layout-picker">
          <span class="study-subtitle small text-muted study-layout-label" data-study-group-grid-target="label">3 per row</span>
          <button type="button" class="study-layout-button" aria-label="1 tile per row" aria-pressed="false" data-study-group-grid-target="option" data-columns="1" data-action="click->study-group-grid#selectLayout">
            <span class="study-layout-preview study-layout-preview-1" aria-hidden="true">
              <span></span>
            </span>
          </button>
          <button type="button" class="study-layout-button" aria-label="2 tiles per row" aria-pressed="false" data-study-group-grid-target="option" data-columns="2" data-action="click->study-group-grid#selectLayout">
            <span class="study-layout-preview study-layout-preview-2" aria-hidden="true">
              <span></span><span></span>
              <span></span><span></span>
            </span>
          </button>
          <button type="button" class="study-layout-button" aria-label="3 tiles per row" aria-pressed="false" data-study-group-grid-target="option" data-columns="3" data-action="click->study-group-grid#selectLayout">
            <span class="study-layout-preview study-layout-preview-3" aria-hidden="true">
              <span></span><span></span><span></span>
              <span></span><span></span><span></span>
              <span></span><span></span><span></span>
            </span>
          </button>
          <% if @query.present? %>
            <%= link_to "Clear", study_groups_path, class: "btn btn-link link-secondary px-0 study-subtitle" %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

<% if @study_groups.empty? %>
  <div class="alert alert-light border text-center p-5 study-subtitle">
    <% if @query.present? %>
      No groups matched "<%= @query %>".
    <% else %>
      No groups yet. Create the first one!
    <% end %>
  </div>
<% end %>

  <div class="study-group-grid" data-study-group-grid-target="grid">
    <% @study_groups.each do |group| %>
      <% current_user_is_member = group.members.include?(current_user) %>
      <div class="col d-flex">
        <div class="group-card h-100 w-100 d-flex flex-column">
        <div class="group-banner-wrapper">
  <% default_banner = "https://upload.wikimedia.org/wikipedia/commons/a/aa/Claude_Monet_-_Water_Lilies_-_1906%2C_Ryerson.jpg" %>
  
  <%# .presence checks if the column is filled. If empty, it uses the default banner %>
  <img src="<%= group.banner_url.presence || default_banner %>" alt="<%= group.name %> Banner" class="group-banner">
        </div>

      <div class="group-card-body">
        <div class="row g-3">
          <div class="col-12 col-md-7">
            <h2 class="group-name">
              <%= link_to group.name, study_group_path(group) %>
            </h2>
            
            <div class="study-subtitle mb-3 text-nowrap group-created-row">
              Created by&nbsp;<strong><%= group.creator.name %></strong>
            </div>

            <div class="study-subtitle d-flex align-items-start gap-1 flex-nowrap group-time-row mb-3">
              <%= image_tag "/clock.png",
                alt: "Clock Icon",
                class: "group-time-icon",
                style: "image-rendering: pixelated;" %>
              <span class="group-time-text">
                <%= study_group_schedule(group) %>
              </span>
            </div>
            
            <% if group.description.present? %>
              <div class="group-description text-muted" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; word-break: break-word;">
                <%= group.description %>
              </div>
            <% end %>
          </div>
        </div>

        <div class="group-tags-row d-flex flex-wrap gap-2 mb-3 mt-3">
          <% group.all_tags.each_with_index do |tag, index| %>
            <% custom_colors = ["#ffe7a3", "#a3ffab", "#f6bdff", "#bde7ff", "#ffc4bd"] %>
            <% bg_color = custom_colors[index % custom_colors.length] %>
            <span class="badge group-tag-badge" style="background-color: <%= bg_color %>;">
              #<%= tag %>
            </span>
          <% end %>
        </div>

        <div class="row g-3 align-items-center study-group-bottom-row">
          <div class="col-12 col-md-7">
            <div class="meta-row">
             <span class="orange-dot"></span> <%= pluralize(group.members.size, "Member") %>
            </div>
          </div>
          <div class="col-12 col-md-5 text-md-end">
            <div>
              <% if current_user_is_member %>
                <% if group.creator == current_user %>
                  <div class="group-owner-note text-muted small study-subtitle text-nowrap d-inline-flex align-items-center justify-content-end w-100">
                    You created this group.
                  </div>
                <% else %>
                  <%= button_to "Leave Group", leave_study_group_path(group), method: :delete, class: "btn btn-outline-danger btn-sm", form: { data: { turbo_confirm: "Leave #{group.name}?" } } %>
                <% end %>
              <% else %>
                <%= form_with url: join_study_group_path(group), method: :post, class: "d-grid gap-2" do |join_form| %>
                  <% if group.password_protected? %>
                    <%= password_field_tag :join_password, nil, class: "form-control form-control-sm", placeholder: "Password" %>
                  <% else %>
                    <%= hidden_field_tag :join_password, "" %>
                  <% end %>
                  <div class="d-inline-flex justify-content-end align-items-center gap-2">
                    <span class="badge <%= group.password_protected? ? "text-bg-warning" : "text-bg-success" %>">
                      <%= group.password_protected? ? "Password" : "Open" %>
                    </span>
                    <%= join_form.submit "Join Group", class: "btn btn-outline-primary btn-sm" %>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>

      </div>
    </div>
      </div>
    <% end %>
  </div>
</div>