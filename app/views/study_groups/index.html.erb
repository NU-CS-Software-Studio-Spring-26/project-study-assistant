<% content_for :title, "Groups" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="h2 mb-1">Study Groups</h1>
    <p class="text-muted mb-0">Find a group that matches your study style.</p>
  </div>
  <%= link_to "New Study Group", new_study_group_path, class: "btn btn-primary" %>
</div>

<% if @study_groups.empty? %>
  <div class="alert alert-info">No groups yet. Create the first one.</div>
<% end %>

<div class="d-grid gap-3">
  <% @study_groups.each do |group| %>
    <div class="card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3">
          <div>
            <h2 class="h5 mb-1">
              <%= link_to group.name, study_group_path(group), class: "text-decoration-none" %>
            </h2>
            <div class="text-muted mb-2">Created by <%= group.creator.name %></div>
            <div class="mb-2"><strong>Starts:</strong> <%= group.start_time.strftime("%a, %b %-d at %-I:%M %p") %></div>
            <div class="mb-2"><strong>Ends:</strong> <%= group.end_time.strftime("%a, %b %-d at %-I:%M %p") %></div>
            <div class="d-flex flex-wrap gap-2 mb-2">
              <% group.all_tags.each do |tag| %>
                <span class="badge text-bg-secondary"><%= tag %></span>
              <% end %>
            </div>
            <div><strong>Members:</strong> <%= group.members.size %></div>
          </div>

          <div class="text-end" style="min-width: 210px;">
            <div class="mb-2">
              <%= link_to "Open Group", study_group_path(group), class: "btn btn-sm btn-primary" %>
            </div>
            <%= form_with url: join_study_group_path(group), method: :post,
                          html: {
                            class: "js-join-group-form",
                            data: { protected: group.password_protected?, group_name: group.name }
                          } do |join_form| %>
              <%= hidden_field_tag :join_password, "", class: "js-join-password-input" %>
              <div class="d-inline-flex align-items-center gap-2">
                <span class="badge <%= group.password_protected? ? "text-bg-warning" : "text-bg-success" %>">
                  <%= group.password_protected? ? "Password" : "Open" %>
                </span>
                <%= join_form.submit "Join Group", class: "btn btn-outline-primary btn-sm" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener("turbo:load", function () {
    document.querySelectorAll(".js-join-group-form").forEach(function (form) {
      form.addEventListener("submit", function (event) {
        var isProtected = form.dataset.protected === "true";
        var passwordInput = form.querySelector(".js-join-password-input");

        if (!isProtected) {
          passwordInput.value = "";
          return;
        }

        var enteredPassword = window.prompt("Enter password to join " + form.dataset.groupName + ":", "");
        if (enteredPassword === null) {
          event.preventDefault();
          return;
        }

        passwordInput.value = enteredPassword;
      });
    });
  });
</script>
