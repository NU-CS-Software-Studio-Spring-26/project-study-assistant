<% content_for :title, "Groups" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="h2 mb-1">Study Groups</h1>
    <p class="text-muted mb-0">Find a group that matches your study style.</p>
  </div>
  <%= link_to "New Study Group", new_study_group_path, class: "btn btn-primary" %>
</div>

<% if @study_groups.empty? %>
  <div class="alert alert-info">No groups yet. Create the first one.</div>
<% end %>

<div class="d-grid gap-3">
  <% @study_groups.each do |group| %>
    <% current_user_is_member = group.members.include?(current_user) %>
    <div class="card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3">
          <div>
            <h2 class="h5 mb-1">
              <%= link_to group.name, study_group_path(group), class: "text-decoration-none" %>
            </h2>
            <div class="text-muted mb-2">Created by <%= group.creator.name %></div>
            <div class="mb-2"><strong>Starts:</strong> <%= group.start_time.strftime("%a, %b %-d at %-I:%M %p") %></div>
            <div class="mb-2"><strong>Ends:</strong> <%= group.end_time.strftime("%a, %b %-d at %-I:%M %p") %></div>
   
            <%= render "description", group: group %>

            <div class="d-flex flex-wrap gap-2 mb-2">
      <% # 1. Define your own custom hex colors here %>
      <% custom_colors = ["#ffe7a3", "#a3ffab", "#f6bdff", "#bde7ff", "#ffc4bd"] %>
      
      <% group.all_tags.each_with_index do |tag, index| %>
        <% # 2. Pick a color using the same modulo logic %>
        <% bg_color = custom_colors[index % custom_colors.length] %>
        
        <span class="badge" 
              style="background-color: <%= bg_color %>; color: #333; border: 1px solid rgba(0,0,0,0.1);">
          <%= tag %>
        </span>
      <% end %>
    </div>


    

            <div><strong>Members:</strong> <%= group.members.size %></div>
          </div>
    

    

          <div class="text-end" style="min-width: 210px;">
            <div class="mb-2">
              <% if current_user_is_member %>
                <%= link_to "Enter Group", study_group_path(group), class: "btn btn-sm btn-primary" %>
              <% else %>
                <span class="badge text-bg-secondary">Join to enter</span>
              <% end %>
            </div>
            <% if current_user_is_member %>
              <% if group.creator == current_user %>
                <div class="text-muted small">You created this group.</div>
              <% else %>
                <%= button_to "Leave Group", leave_study_group_path(group), method: :delete, class: "btn btn-outline-danger btn-sm", form: { data: { turbo_confirm: "Leave #{group.name}?" } } %>
              <% end %>
            <% else %>
              <%= form_with url: join_study_group_path(group), method: :post, class: "d-grid gap-2" do |join_form| %>
                <% if group.password_protected? %>
                  <%= password_field_tag :join_password, nil, class: "form-control form-control-sm", placeholder: "Password" %>
                <% else %>
                  <%= hidden_field_tag :join_password, "" %>
                <% end %>
                <div class="d-inline-flex justify-content-end align-items-center gap-2">
                  <span class="badge <%= group.password_protected? ? "text-bg-warning" : "text-bg-success" %>">
                    <%= group.password_protected? ? "Password" : "Open" %>
                  </span>
                  <%= join_form.submit "Join Group", class: "btn btn-outline-primary btn-sm" %>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
