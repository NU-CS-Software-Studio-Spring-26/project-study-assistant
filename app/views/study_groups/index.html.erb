<p style="color: green"><%= notice %></p>
<p style="color: red"><%= alert %></p>

<% content_for :title, "Groups" %>

<div class="row g-4">
  <div class="col-lg-5">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h4 mb-3">Create A Study Group</h2>

        <% if @study_group.errors.any? %>
          <div class="alert alert-danger">
            <strong>Could not create group:</strong>
            <ul class="mb-0 mt-2">
              <% @study_group.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: @study_group, url: study_groups_path do |form| %>
          <div class="mb-3">
            <%= form.label :name, "Group Name", class: "form-label" %>
            <%= form.text_field :name, class: "form-control", placeholder: "BIO 101 Midterm Sprint" %>
          </div>

          <div class="mb-3">
            <%= form.label :creator_id, "Created By", class: "form-label" %>
            <%= form.collection_select :creator_id, @users, :id, :name, { prompt: "Select a user" }, class: "form-select" %>
          </div>

          <div class="mb-3">
            <%= form.label :study_time, "Study Time", class: "form-label" %>
            <%= form.datetime_local_field :study_time, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= form.label :location_mode, "Online Or In Person", class: "form-label" %>
            <%= form.select :location_mode, StudyGroup::LOCATION_MODES, { prompt: "Choose one" }, class: "form-select" %>
          </div>

          <div class="mb-3">
            <%= form.label :communication_style, "Group Style", class: "form-label" %>
            <%= form.select :communication_style, StudyGroup::COMMUNICATION_STYLES, { prompt: "Choose one" }, class: "form-select" %>
          </div>

          <fieldset class="mb-3">
            <legend class="col-form-label pt-0">Extra Tags</legend>
            <% ["Focused", "Accountability", "Exam Prep", "Homework Help"].each do |tag| %>
              <div class="form-check">
                <%= check_box_tag "study_group[tags][]", tag, false, id: "study_group_tags_#{tag.parameterize}", class: "form-check-input" %>
                <%= label_tag "study_group_tags_#{tag.parameterize}", tag, class: "form-check-label" %>
              </div>
            <% end %>
          </fieldset>

          <div class="mb-3">
            <%= label_tag :extra_tags, "Custom Tags (comma separated)", class: "form-label" %>
            <%= text_field_tag :extra_tags, nil, class: "form-control", placeholder: "weekend, library, calculus" %>
          </div>

          <%= form.submit "Create Group", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-7">
    <h1 class="h3 mb-3">Study Groups</h1>

    <% if @study_groups.empty? %>
      <div class="alert alert-info">No groups yet. Create the first one.</div>
    <% end %>

    <div class="d-grid gap-3">
      <% @study_groups.each do |group| %>
        <div class="card">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3">
              <div>
                <h3 class="h5 mb-1"><%= group.name %></h3>
                <div class="text-muted mb-2">Created by <%= group.creator.name %></div>
                <div class="mb-2">
                  <strong>Time:</strong>
                  <%= group.study_time.strftime("%a, %b %-d at %-I:%M %p") %>
                </div>
                <div class="d-flex flex-wrap gap-2 mb-2">
                  <% group.all_tags.each do |tag| %>
                    <span class="badge text-bg-secondary"><%= tag %></span>
                  <% end %>
                </div>
                <div>
                  <strong>Members:</strong>
                  <%= group.members.map(&:name).join(", ").presence || "No members yet" %>
                </div>
              </div>

              <div class="text-end" style="min-width: 210px;">
                <%= form_with url: join_study_group_path(group), method: :post do |join_form| %>
                  <div class="mb-2">
                    <%= join_form.label :user_id, "Join as", class: "form-label" %>
                    <%= join_form.collection_select :user_id, @users, :id, :name, { prompt: "Select user" }, class: "form-select form-select-sm" %>
                  </div>
                  <%= join_form.submit "Join Group", class: "btn btn-outline-primary btn-sm" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>