<div class="row justify-content-center mt-5">
  <div class="col-md-8 text-center">
    <h1 class="display-4 fw-bold mb-3">Study Assistant</h1>
    <p class="lead mb-4">Stay on top of your coursework. Study Assistant syncs your Canvas calendar so you can see all your assignments in one place — organized, clear, and easy to manage.</p>
    <div class="d-flex gap-3 justify-content-center">
      <%= link_to "Get Started", new_user_path, class: "btn btn-primary btn-lg" %>
      <%= link_to "Log In", login_path, class: "btn btn-outline-secondary btn-lg" %>
    </div>

    <div class="row mt-5 text-start">
      <div class="col-md-4">
        <h3>📅 Canvas Sync</h3>
        <p>Connect your Canvas iCal feed and your assignments import automatically.</p>
      </div>
      <div class="col-md-4">
        <h3>📚 Study Groups</h3>
        <p>Create or join study groups to collaborate with classmates.</p>
      </div>
      <div class="col-md-4">
        <h3>✅ Track Progress</h3>
        <p>Mark assignments as done and stay organized throughout the quarter.</p>
      </div>
    </div>
  </div>
</div>