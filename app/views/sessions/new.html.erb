<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card shadow">
      <div class="card-body p-4">
        <h2 class="card-title text-center mb-4">Welcome to Study Assistant </h2>

        <% if flash[:alert] %>
          <div class="alert alert-danger"><%= flash[:alert] %></div>
        <% end %>

        <%= form_with url: login_path, method: :post do |form| %>
          <div class="mb-3">
            <%= form.label :email, "Email", class: "form-label" %>
            <%= form.email_field :email, class: "form-control", placeholder: "your@email.com" %>
          </div>
          <div class="d-grid">
            <%= form.submit "Sign In", class: "btn btn-dark w-100" %>
          </div>
        <% end %>

        <hr>
        <p class="text-center text-muted">New here? <%= link_to "Create an account", new_user_path %></p>
      </div>
    </div>
  </div>
</div>