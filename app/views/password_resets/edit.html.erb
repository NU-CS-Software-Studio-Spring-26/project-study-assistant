<% content_for :title, "Choose New Password" %>

<div class="auth-page row justify-content-center align-items-center py-5">

<div class="blob blob-1"></div>
<div class="blob blob-2"></div>
<div class="blob blob-3"></div>
<div class="blob blob-4"></div>

  <div class="col-md-5">

    <div class="d-flex justify-content-center align-items-center my-4">
      <h3 class="d-flex align-items-center m-0" style="gap: 0.05px; color: #FFF4E0;">
        <img src="/logo.svg" alt="TideTogether Icon" style="width: 5rem; height: 5rem;">
        <span>TideTogether</span>
      </h3>
    </div>

    <h2 class="text-center mb-4" style="color: #504441 !important; font-weight: 700; font-size: 2.5rem; letter-spacing: -0.03em;">
      Choose a new password
    </h2>

    <div class="card shadow-sm auth-card">
      <div class="card-body p-4">
        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with url: "/password/reset", method: :patch do |form| %>
          <%= hidden_field_tag :token, @token %>

          <div class="mb-3">
            <%= form.label :password, "New Password", class: "form-label" %>
            <%= form.password_field :password, name: :password, class: "form-control", autocomplete: "new-password" %>
            <div class="form-text">Minimum 8 characters.</div>
          </div>

          <div class="mb-3">
            <%= form.label :password_confirmation, "Confirm New Password", class: "form-label" %>
            <%= form.password_field :password_confirmation, name: :password_confirmation, class: "form-control", autocomplete: "new-password" %>
          </div>

          <div class="d-grid">
            <%= form.submit "Update Password", class: "btn btn-primary w-100" %>
          </div>
        <% end %>

        <hr>
        <p class="text-center auth-copy mb-0">
          Remember your password? <%= link_to "Sign in", login_path %>
        </p>
      </div>
    </div>
  </div>
</div>
